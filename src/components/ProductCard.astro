---

interface Props {
    bgImage: string;
    title: string;
    price: string;
}

const { bgImage, title, price } = Astro.props;
---

<article class={`bg-[url('/recetas/${bgImage}')] relative bg-cover aspect-4/3 bg-center bg-no-repeat rounded-lg w-full h-72 shadow-xl shadow-black/50 border-double border-2 border-black/30 hover:scale-[1.02] transition-all duration-150 animate-expandir `}>
    <footer class="absolute bottom-0 w-full h-fit flex items-center justify-center gap-2 bg-black/80 p-2 text-white rounded-b-lg">
        <p class="text-xl font-bold">
            {title}
        </p>
        <p class="text-sm">
            {price}
        </p>
    </footer>
</article>